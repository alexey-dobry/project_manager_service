# ─── приложение ───
APP_NAME=api-gateway
APP_ENV=dev

# ─── HTTP ───
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_SHUTDOWN_TIMEOUT=10s

# ─── JWT ───
# JWT_SECRET должен совпадать на всех сервисах системы.
JWT_SECRET=change-me-please-32-chars-minimum-secret

# ─── upstreams ───
# В docker-compose — имена сервисов, локально — localhost:порт.
UPSTREAM_AUTH=http://auth-service:8081
UPSTREAM_GROUPS=http://groups-service:8082
UPSTREAM_PROJECTS=http://projects-service:8083
UPSTREAM_TIMEOUT=15s

# ─── rate limit ───
RATE_LIMIT_MAX=100
RATE_LIMIT_DURATION=1m

# ─── CORS ───
CORS_ALLOW_ORIGINS=*

# ─── logger ───
LOGGER_LEVEL=debug
LOGGER_FORMAT=console
