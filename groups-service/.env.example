# ─── приложение ───
APP_NAME=groups-service
APP_ENV=dev

# ─── HTTP ───
HTTP_HOST=0.0.0.0
HTTP_PORT=8082
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_SHUTDOWN_TIMEOUT=10s

# ─── PostgreSQL ───
# В docker-compose имя хоста — groups-postgres; локально (вне Docker) — localhost.
POSTGRES_HOST=groups-postgres
POSTGRES_PORT=5432
POSTGRES_USER=groups
POSTGRES_PASSWORD=groups
POSTGRES_DBNAME=groups
POSTGRES_SSLMODE=disable

# ─── JWT ───
# JWT_SECRET должен совпадать на всех сервисах системы.
JWT_SECRET=change-me-please-32-chars-minimum-secret

# ─── auth-service ───
# Используется для обогащения GET /groups/{id} данными участников
# (ФИО, роль) — groups-service хранит только UserID.
AUTH_SERVICE_URL=http://auth-service:8081

# ─── logger ───
LOGGER_LEVEL=debug
LOGGER_FORMAT=console
