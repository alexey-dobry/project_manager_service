# Корневой .env для docker-compose. Скопируйте в .env: cp .env.example .env
#
# Здесь — только переменные, которые нужны на уровне compose
# (с подстановкой через ${...}). Локальные настройки каждого сервиса —
# в его собственном .env.example.

# Один секрет для всех сервисов: auth-service подписывает им JWT,
# groups-service / projects-service / api-gateway им же проверяют.
# В проде — секрет-менеджер (Vault, AWS Secrets Manager, ...).
JWT_SECRET=change-me-please-32-chars-minimum-secret
