# ─── приложение ───
APP_NAME=projects-service
APP_ENV=dev

# ─── HTTP ───
HTTP_HOST=0.0.0.0
HTTP_PORT=8083
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_SHUTDOWN_TIMEOUT=10s

# ─── PostgreSQL ───
POSTGRES_HOST=projects-postgres
POSTGRES_PORT=5432
POSTGRES_USER=projects
POSTGRES_PASSWORD=projects
POSTGRES_DBNAME=projects
POSTGRES_SSLMODE=disable

# ─── JWT ───
# ВАЖНО: должен совпадать с auth-service.
JWT_SECRET=change-me-please-32-chars-minimum-secret

# ─── logger ───
LOGGER_LEVEL=debug
LOGGER_FORMAT=console
