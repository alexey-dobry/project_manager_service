# ─── приложение ───
APP_NAME=auth-service
APP_ENV=dev                       # dev | prod

# ─── HTTP ───
HTTP_HOST=0.0.0.0
HTTP_PORT=8081
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_SHUTDOWN_TIMEOUT=10s

# ─── PostgreSQL ───
# В docker-compose имя хоста — auth-postgres; локально (вне Docker) — localhost.
POSTGRES_HOST=auth-postgres
POSTGRES_PORT=5432
POSTGRES_USER=auth
POSTGRES_PASSWORD=auth
POSTGRES_DBNAME=auth
POSTGRES_SSLMODE=disable

# ─── JWT ───
# Минимум 16 символов. Должен совпадать на всех сервисах системы.
JWT_SECRET=change-me-please-32-chars-minimum-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h              # 30 дней
JWT_ISSUER=auth-service

# ─── bcrypt ───
BCRYPT_COST=10

# ─── logger ───
LOGGER_LEVEL=debug                # trace|debug|info|warn|error
LOGGER_FORMAT=console             # console|json
